# ─── Casper testnet ───────────────────────────────────────────────
# Public testnet RPC. Swap for your own node or a CSPR.cloud endpoint.
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# Deployed CaliberVault contract PACKAGE hash (fill after deployment).
CALIBER_VAULT_CONTRACT_HASH=
# Agent signing key (path to a Casper secret_key.pem). NEVER commit the key.
CASPER_SECRET_KEY_PATH=./keys/agent_secret_key.pem
# Signing algorithm: ed25519 (default) or secp256k1.
CALIBER_KEY_ALGO=ed25519
# Payment (motes) for the record_rebalance call. Tune after the first deploy.
CALIBER_PAYMENT_MOTES=2500000000

# ─── Agent loop ───────────────────────────────────────────────────
# When true, the agent recommends but never submits a real deploy (safe default).
CALIBER_DRY_RUN=true
# How often the scheduler runs the loop, in milliseconds.
CALIBER_LOOP_INTERVAL_MS=60000

# ─── Persistence ──────────────────────────────────────────────────
# Local dev (default): SQLite file at this path.
CALIBER_SQLITE_PATH=./data/caliber.dev.sqlite
# Production: set a Postgres URL and it takes precedence over SQLite.
# CALIBER_DATABASE_URL=postgres://user:pass@host:5432/caliber
# Force in-memory (no durability), e.g. for CI: CALIBER_DB=memory

# ─── HTTP API (consumed by the web dashboard) ─────────────────────
CALIBER_API_PORT=4000
CALIBER_CORS_ORIGIN=http://localhost:3000

# ─── AI (model-agnostic via the Vercel AI SDK) ────────────────────
# Provider: 'anthropic' (default) or 'openrouter'. The provider selects which
# key is used and a default model. Leave the key empty to use the deterministic
# offline fallback (no LLM).
CALIBER_LLM_PROVIDER=anthropic

# anthropic: Claude directly.
ANTHROPIC_API_KEY=

# openrouter: one key across many providers + automatic provider fallbacks.
#   CALIBER_LLM_PROVIDER=openrouter
#   OPENROUTER_API_KEY=sk-or-...
#   CALIBER_DECISION_MODEL=openai/gpt-4o-mini   # pin a model; do NOT use auto-routing
OPENROUTER_API_KEY=

# Override the model for the active provider (default: claude-opus-4-8 for
# anthropic, openai/gpt-4o-mini for openrouter).
CALIBER_DECISION_MODEL=

# Independent Risk-Officer reviews per rebalance (majority veto). 3 is safer but
# 3x the review cost/latency; set 1 for a cheaper demo.
CALIBER_REVIEW_VOTES=3

# ─── Casper MCP Server (optional, for on-chain reads) ─────────────
# SSE URL of a running Casper MCP server. Unset = skip MCP, use direct RPC.
CALIBER_CASPER_MCP_URL=

# ─── External market / RWA data sources (when wiring real signals) ─
RWA_FEED_URL=
MARKET_DATA_API_KEY=
