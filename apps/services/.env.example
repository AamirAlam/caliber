# ─── Casper testnet ───────────────────────────────────────────────
# Public testnet RPC. Swap for your own node or a CSPR.cloud endpoint.
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# Deployed Helm vault contract package hash (fill after deployment).
HELM_VAULT_CONTRACT_HASH=

# Agent signing key (path to a Casper secret_key.pem). NEVER commit the key.
CASPER_SECRET_KEY_PATH=./keys/agent_secret_key.pem

# ─── CSPR.cloud (optional middleware) ─────────────────────────────
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud

# ─── AI provider (decision explanations) ──────────────────────────
ANTHROPIC_API_KEY=
HELM_DECISION_MODEL=claude-opus-4-8

# ─── External market / RWA data sources ───────────────────────────
RWA_FEED_URL=
MARKET_DATA_API_KEY=

# ─── Agent loop ───────────────────────────────────────────────────
# How often the scheduler runs the loop, in milliseconds.
HELM_LOOP_INTERVAL_MS=60000
# When true, the agent only recommends and never submits a deploy.
HELM_DRY_RUN=true
