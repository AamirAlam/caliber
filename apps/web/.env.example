# Public base URL of the off-chain services API (when wired up).
NEXT_PUBLIC_SERVICES_URL=http://localhost:4000

# Casper network the UI labels itself with.
NEXT_PUBLIC_CASPER_NETWORK=casper-testnet

# Public CSPR.live explorer base for linking deploy hashes.
NEXT_PUBLIC_EXPLORER_BASE=https://testnet.cspr.live

# Deployed Helm vault contract hash (for explorer links / read-only views).
NEXT_PUBLIC_VAULT_CONTRACT_HASH=
