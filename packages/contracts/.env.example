# Casper testnet deployment config (used by scripts/deploy_testnet.sh).
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test

# Path to the deployer's secret key (NEVER commit). Fund it from the faucet:
# https://testnet.cspr.live/tools/faucet
CASPER_SECRET_KEY_PATH=./keys/secret_key.pem

# Payment for the install deploy, in motes.
CASPER_INSTALL_PAYMENT=200000000000

# Constructor args.
VAULT_OWNER_ACCOUNT_HASH=
VAULT_POLICY_REF=policy:demo
